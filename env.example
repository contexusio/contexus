
# === Core Database Configuration ===
POSTGRES_PASSWORD=your_secure_postgres_password
REDIS_PASSWORD=your_secure_redis_password

# === Application Security ===
SESSION_SECRET=your_256_bit_session_secret_here
ADMIN_PASSWORD=your_secure_admin_password
JWT_SECRET=your_256_bit_jwt_secret_here

# === Email Configuration ===
EMAIL_PASSWORD=your_email_password
SMTP_HOST=
SMTP_PORT=
SMTP_USER=

# === Application Configuration ===
NODE_ENV=production
APP_PORT=15000
LOG_LEVEL=info
LOG_FORMAT=json

# === Database URLs (Auto-generated from above) ===
DATABASE_URL=postgresql://contexus:${POSTGRES_PASSWORD}@postgres:5432/contexus
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# === Security & CORS ===
FORCE_HTTPS=false
ALLOWED_ORIGINS=http://localhost:15000,http://127.0.0.1:15000
ALLOWED_NO_ORIGINS=true

# === Optional: Custom Ports ===
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# === Optional: Data Directory ===
DATA_DIR=./data

# === Optional: Monitoring ===
GRAFANA_PASSWORD=admin
